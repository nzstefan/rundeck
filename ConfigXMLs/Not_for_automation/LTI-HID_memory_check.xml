<?xml version="1.0" encoding="utf-8"?>

<basemem_check_info>
<!--File format version-->
<format_ver>02</format_ver>
<logger_model>LTI-HID</logger_model>
<firmware_version>6.01</firmware_version>
	<memory_check>
		<name>PRODUCT_ID</name>
		<mem_address_hex>07</mem_address_hex>
		<length>1</length>
		<big_endian>yes</big_endian>
		<range>no</range>
		<!--Exact value to match in HEX-->
		<value>00</value>
	</memory_check>
	<memory_check>
		<name>FORMAT_VER</name>
		<mem_address_hex>08</mem_address_hex>
		<length>1</length>
		<big_endian>yes</big_endian>
		<range>no</range>
		<!--Exact value to match in HEX-->
		<value>00</value>
	</memory_check>
	<memory_check>
		<name>BAUD_RATE</name>
		<mem_address_hex>09</mem_address_hex>
		<length>1</length>
		<big_endian>yes</big_endian>
		<range>no</range>
		<!--Exact value to match in HEX-->
		<value>35</value>
	</memory_check>
	<memory_check>
		<name>PRE</name>
		<mem_address_hex>0B</mem_address_hex>
		<length>1</length>
		<big_endian>yes</big_endian>
		<range>no</range>
		<value>02</value>
	</memory_check>
	<memory_check>
		<name>TX_DELAY</name>
		<mem_address_hex>0D</mem_address_hex>
		<length>1</length>
		<big_endian>yes</big_endian>
		<range>no</range>
		<value>02</value>		
	</memory_check>
	<memory_check>
		<name>RX_STARTCHAR_DELAY</name>
		<mem_address_hex>0E</mem_address_hex>
		<length>1</length>
		<!--yes, if a multi-byte value is stored in big endian, no, if little endian-->
		<big_endian>yes</big_endian>
		<!--yes, if a range of values is accepted, no, if value has to match exactly-->
		<range>no</range>
		<!--Exact value to match in HEX-->
		<value>07</value>		
	</memory_check>
	<memory_check>
		<name>RX_INTERCHAR_DELAY</name>
		<mem_address_hex>0F</mem_address_hex>
		<length>1</length>
		<!--yes, if a multi-byte value is stored in big endian, no, if little endian-->
		<big_endian>yes</big_endian>
		<!--yes, if a range of values is accepted, no, if value has to match exactly-->
		<range>no</range>
		<!--Exact value to match in HEX-->
		<value>08</value>		
	</memory_check>
</basemem_check_info>

